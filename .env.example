# DroneRoute Configuration
PORT=3001
JWT_SECRET=change-this-to-a-random-secret
DB_PATH=./data/droneroute.db

# Self-hosted mode (default: true). Set to false for cloud deployments.
SELF_HOSTED=true

# Allowed cross-origin origins (comma-separated). Only needed when the frontend
# is served from a different origin than the API. Leave unset for the standard
# setup (the SPA is served same-origin), which disables cross-origin requests.
# CORS_ORIGIN=https://app.example.com,https://www.example.com

# Admin email — only used when SELF_HOSTED=false. The user with this email
# gets admin privileges and access to the back office panel.
# ADMIN_EMAIL=admin@example.com

# Mapbox access token (required for map rendering).
# Get yours at https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=your-mapbox-token-here
